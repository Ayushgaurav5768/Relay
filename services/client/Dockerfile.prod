FROM node:20-alpine AS build
WORKDIR /app

COPY package.json package-lock.json ./
COPY services/client/package.json services/client/package.json

RUN npm ci --no-audit --no-fund

COPY services/client/ services/client/

WORKDIR /app/services/client
RUN npm run build
WORKDIR /app

# Exit immediately — Docker copies /app/services/client/dist into the
# named volume on first start, then nginx serves from that volume.
CMD ["node", "-e", "process.exit(0)"]
