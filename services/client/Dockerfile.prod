FROM node:20-alpine AS build
WORKDIR /app

COPY package.json package-lock.json ./
COPY services/client/package.json services/client/package.json

RUN npm ci --no-audit --no-fund

COPY services/client/ services/client/

RUN npm run build

# Output is at /app/services/client/dist — consumed by the nginx service
# via a named volume in docker-compose.prod.yml
