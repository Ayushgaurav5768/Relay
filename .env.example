# ──────────────────────────────────────────────
# Relay — Environment Configuration
# ──────────────────────────────────────────────
# Copy this file to .env and fill in values.
#   cp .env.example .env

# ── PostgreSQL ────────────────────────────────
PGHOST=localhost
PGPORT=5432
PGDATABASE=relay
PGUSER=relay
PGPASSWORD=relay_dev

# ── Redis ─────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── RabbitMQ ──────────────────────────────────
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=relay
RABBITMQ_PASSWORD=relay_dev

# ── Ingest Service ───────────────────────────
INGEST_PORT=3001
INGEST_HMAC_SECRET=change-me-in-production
# API key mapping: owner_id1:api_key1,owner_id2:api_key2
INGEST_API_KEYS=org_acme:dev-api-key
# Rate limiting — token bucket refill rate
INGEST_RATE_LIMIT_RATE=10
INGEST_RATE_LIMIT_INTERVAL_MS=1000

# ── Delivery Worker ──────────────────────────
DELIVERY_WORKER_PORT=3002
DELIVERY_HMAC_SECRET=change-me-in-production
# Max concurrent deliveries per destination queue (prevents one destination's
# backlog from starving others — each queue gets its own prefetch window)
DELIVERY_CONCURRENCY=5
MAX_RETRIES=5
CB_FAILURE_THRESHOLD=5
CB_COOLDOWN_SECONDS=30
CB_HALF_OPEN_SUCCESS_THRESHOLD=2

# ── Dashboard API ────────────────────────────
DASHBOARD_PORT=3003

# ── Flaky Endpoint Test Server ────────────────
FLAKY_PORT=9099
FLAKY_EVERY=3          # Succeed every Nth request
FLAKY_LATENCY=0        # Artificial delay in ms
FLAKY_FAIL_STATUS=500  # HTTP status for "failure" responses

# ── Client (Vite dev server) ─────────────────
CLIENT_PORT=5173
VITE_DASHBOARD_API_URL=http://localhost:3003

# ── General ──────────────────────────────────
LOG_LEVEL=info
NODE_ENV=development
