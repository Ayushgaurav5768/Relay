# =============================================================================
# Relay — Production Environment Variables
# =============================================================================
# Copy to .env.production and fill in your secrets.
# To deploy:  bash infra/scripts/deploy.sh production
# NEVER commit .env.production to version control.
# =============================================================================

# ── Database ─────────────────────────────────────────────────────────────────
PGDATABASE=relay
PGUSER=relay
PGPASSWORD=change-me-to-a-strong-password

# ── RabbitMQ ────────────────────────────────────────────────────────────────
RABBITMQ_USER=relay
RABBITMQ_PASSWORD=change-me-to-a-strong-password

# ── HMAC Secrets (webhook payload signing + ingest auth) ────────────────────
INGEST_HMAC_SECRET=change-me-to-a-random-64-char-secret
DELIVERY_HMAC_SECRET=change-me-to-a-random-64-char-secret

# ── API Authentication (Basic Auth — comma-separated org:key pairs) ─────────
INGEST_API_KEYS=org_acme:prod-api-key-here

# ── Rate Limiting ───────────────────────────────────────────────────────────
INGEST_RATE_LIMIT_RATE=100
INGEST_RATE_LIMIT_INTERVAL_MS=1000

# ── Delivery Configuration ──────────────────────────────────────────────────
DELIVERY_CONCURRENCY=10
MAX_RETRIES=5
CB_FAILURE_THRESHOLD=5
CB_COOLDOWN_SECONDS=30
CB_HALF_OPEN_SUCCESS_THRESHOLD=2

# ── Observability ───────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Image Configuration (optional — defaults to latest from GHCR) ──────────
# IMAGE_NAMESPACE=ghcr.io/ayushgaurav5768/relay
# IMAGE_TAG=latest
